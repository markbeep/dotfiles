// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "cli_default_open_behavior": "existing_window",
  "project_panel": {
    "dock": "left",
  },
  "outline_panel": {
    "dock": "left",
  },
  "collaboration_panel": {
    "dock": "left",
  },
  "git_panel": {
    "dock": "left",
  },
  "inlay_hints": {
    "enabled": false,
  },
  "show_wrap_guides": true,
  "search": {
    "center_on_match": true,
  },
  "terminal": {
    "env": {},
    "font_family": "Fira Code",
    "font_fallbacks": ["Fira Code", ".ZedMono"],
  },
  "base_keymap": "VSCode",
  "sticky_scroll": {
    "enabled": false,
  },
  "minimap": {
    "show": "never",
  },
  "edit_predictions": {
    "provider": "copilot",
    "mode": "subtle",
  },
  "file_types": {
    "Dockerfile": ["*Dockerfile*"],
    "Django": ["*.j2", "*.html", "*.jinja"],
  },
  "buffer_line_height": "standard",
  "ui_font_family": ".ZedSans",
  "buffer_font_family": "Fira Code",
  "icon_theme": {
    "mode": "dark",
    "light": "Catppuccin Latte",
    "dark": "Catppuccin Latte",
  },
  "agent": {
    "dock": "right",
    "default_profile": "write",
    "tool_permissions": {
      "tools": {
        "open": {
          "default": "deny",
        },
        "terminal": {
          "always_allow": [
            {
              "pattern": "^cd\\b",
            },
            {
              "pattern": "^grep\\b",
            },
            {
              "pattern": "^ls\\b",
            },
            {
              "pattern": "^cat\\s+src/game/scenes/Game\\.ts(\\s|$)",
            },
            {
              "pattern": "^cat\\s+src/game/main\\.ts(\\s|$)",
            },
          ],
        },
        "create_directory": {
          "default": "allow",
        },
        "edit_file": {
          "always_allow": [
            {
              "pattern": "^frontend/src/components/icons/",
            },
          ],
        },
      },
    },
    "default_model": {
      "effort": "high",
      "enable_thinking": true,
      "provider": "deepseek",
      "model": "deepseek-v4-pro",
    },
    "favorite_models": [],
    "model_parameters": [],
  },
  "ui_font_size": 16,
  "buffer_font_size": 13.0,
  "theme": {
    "mode": "dark",
    "light": "One Light",
    "dark": "Catppuccin Frappé",
  },
  "lsp": {
    "vtsls": {
      "settings": {
        "javascript": {
          "updateImportsOnFileMove": {
            "enabled": "always",
          },
        },
        "typescript": {
          "updateImportsOnFileMove": {
            "enabled": "always",
          },
          "preferences": {
            "importModuleSpecifier": "non-relative",
          },
        },
      },
    },
    "tailwindcss-language-server": {
      "settings": {
        "includeLanguages": {
          "django": "django-html",
        },
      },
    },
  },
  "languages": {
    "C++": {
      "show_edit_predictions": false,
    },
    "GLSL": {
      "show_edit_predictions": false,
    },
    "Go": {
      "show_edit_predictions": false,
    },
    "Django": {
      "formatter": {
        "external": {
          "command": "uv",
          "arguments": ["run", "djlint", "-", "--reformat", "{buffer_path}"],
        },
      },
    },
    "Markdown": {
      "format_on_save": "on",
    },
    "Astro": {
      "formatter": "language_server",
    },
  },
  "semantic_tokens": "combined",
  "global_lsp_settings": {
    "semantic_token_rules": [
      {
        "token_type": "todoKeyword",
        "foreground_color": "#FF8C00",
        "background_color": "#2B1700",
        "font_weight": "bold",
      },
      {
        "token_type": "fixmeKeyword",
        "foreground_color": "#FF2D55",
        "background_color": "#2B0011",
        "font_weight": "bold",
      },
      {
        "token_type": "hackKeyword",
        "foreground_color": "#FFD60A",
        "background_color": "#272100",
        "font_weight": "bold",
      },
      {
        "token_type": "noteKeyword",
        "foreground_color": "#0A84FF",
        "background_color": "#001B2B",
        "font_weight": "bold",
      },
      {
        "token_type": "infoKeyword",
        "foreground_color": "#0A84FF",
        "background_color": "#001B2B",
        "font_weight": "bold",
      },
      {
        "token_type": "warnKeyword",
        "foreground_color": "#FF9F0A",
        "background_color": "#271B00",
        "font_weight": "bold",
      },
      {
        "token_type": "warningKeyword",
        "foreground_color": "#FF9F0A",
        "background_color": "#271B00",
        "font_weight": "bold",
      },
      {
        "token_type": "bugKeyword",
        "foreground_color": "#FF453A",
        "background_color": "#2B0A00",
        "font_weight": "bold",
      },
      {
        "token_type": "xxxKeyword",
        "foreground_color": "#BF5AF2",
        "background_color": "#1B0029",
        "font_weight": "bold",
      },
      {
        "token_type": "deprecatedKeyword",
        "foreground_color": "#98989D",
        "background_color": "#1A1A1A",
        "font_weight": "bold",
      },
    ],
  },
}
