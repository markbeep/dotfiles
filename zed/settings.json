// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "cli_default_open_behavior": "existing_window",
  "project_panel": {
    "dock": "left"
  },
  "outline_panel": {
    "dock": "left"
  },
  "collaboration_panel": {
    "dock": "left"
  },
  "git_panel": {
    "dock": "left"
  },
  "inlay_hints": {
    "enabled": false,
  },
  "show_wrap_guides": true,
  "search": {
    "center_on_match": true,
  },
  "terminal": {
    "env": {},
    "font_family": "Fira Code",
    "font_fallbacks": ["Fira Code", ".ZedMono"],
  },
  "base_keymap": "VSCode",
  "sticky_scroll": {
    "enabled": false,
  },
  "minimap": {
    "show": "never",
  },
  "edit_predictions": {
    "provider": "copilot",
    "mode": "subtle",
  },
  "file_types": {
    "Dockerfile": ["*Dockerfile*"],
    "Django": ["*.j2", "*.html", "*.jinja"],
  },
  "buffer_line_height": "standard",
  "ui_font_family": ".ZedSans",
  "buffer_font_family": "Fira Code",
  "icon_theme": "Catppuccin Latte",
  "agent": {
    "dock": "right",
    "default_profile": "write",
    "tool_permissions": {
      "tools": {
        "open": {
          "default": "deny"
        },
        "terminal": {
          "always_allow": [
            {
              "pattern": "^cd\\b"
            },
            {
              "pattern": "^grep\\b"
            },
            {
              "pattern": "^ls\\b"
            },
            {
              "pattern": "^cat\\s+src/game/scenes/Game\\.ts(\\s|$)"
            },
            {
              "pattern": "^cat\\s+src/game/main\\.ts(\\s|$)"
            }
          ],
        },
        "create_directory": {
          "default": "allow",
        },
        "edit_file": {
          "always_allow": [
            {
              "pattern": "^frontend/src/components/icons/",
            },
          ],
        },
      },
    },
    "default_model": {
      "enable_thinking": true,
      "effort": "high",
      "provider": "copilot_chat",
      "model": "gemini-3.1-pro-preview",
    },
    "favorite_models": [],
    "model_parameters": [],
  },
  "ui_font_size": 16,
  "buffer_font_size": 13.0,
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "Rosé Pine Moon",
  },
  "lsp": {
    "vtsls": {
      "settings": {
        "javascript": {
          "updateImportsOnFileMove": {
            "enabled": "always",
          },
        },
        "typescript": {
          "updateImportsOnFileMove": {
            "enabled": "always",
          },
          "preferences": {
            "importModuleSpecifier": "non-relative",
          },
        },
      },
    },
    "tailwindcss-language-server": {
      "settings": {
        "includeLanguages": {
          "django": "django-html",
        },
      },
    },
  },
  "languages": {
    "Go": {
      "show_edit_predictions": false
    },
    "Django": {
      "formatter": {
        "external": {
          "command": "uv",
          "arguments": ["run", "djlint", "-", "--reformat", "{buffer_path}"],
        },
      },
    },
    "Markdown": {
      "format_on_save": "on",
    },
    "Astro": {
      "formatter": "language_server",
    },
  },
  // "experimental.theme_overrides": {
  //   "editor.active_line.background": "#332f38ff",
  //   "editor.active_line_number": "#c6414d",
  // },
}
